{
  "domain_key": "scsm",
  "table_name": "blocking_statutes",
  "table_type": "fact",
  "type": "struct",
  "version": "1.0",
  "schema_category": "field_metadata",
  "architectural_role": "relational_pair_layer",
  "storage_format": "table",
  "description": "Curated blocking statute matrix feeding ECC.",
  "last_updated": "2026-07-18",
  "update_frequency": "Batch",
  "fields": [
    {
      "name": "id",
      "type": "BIGINT",
      "nullable": false,
      "metadata": {
        "description": "Surrogate primary key",
        "constraint": "PRIMARY_KEY"
      }
    },
    {
      "name": "matrix_version",
      "type": "VARCHAR",
      "nullable": false,
      "metadata": {
        "description": "Version of the blocking matrix"
      }
    },
    {
      "name": "home_jurisdiction_id",
      "type": "BIGINT",
      "nullable": false,
      "metadata": {
        "description": "Foreign key to home jurisdiction"
      }
    },
    {
      "name": "host_jurisdiction_id",
      "type": "BIGINT",
      "nullable": false,
      "metadata": {
        "description": "Foreign key to host jurisdiction"
      }
    },
    {
      "name": "statute_citation",
      "type": "VARCHAR",
      "nullable": false,
      "metadata": {
        "description": "Citation of the statute"
      }
    },
    {
      "name": "severity_score",
      "type": "DECIMAL(4,2)",
      "nullable": false,
      "metadata": {
        "description": "Severity score (0-15)",
        "constraint": "CHECK (severity_score BETWEEN 0 AND 15)"
      }
    },
    {
      "name": "status",
      "type": "VARCHAR",
      "nullable": false,
      "default_value": "'provisional'",
      "metadata": {
        "description": "Status of the statute assessment"
      }
    },
    {
      "name": "updated_at",
      "type": "TIMESTAMP",
      "nullable": false,
      "metadata": {
        "description": "Timestamp of last update"
      }
    }
  ]
}